generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  DOCENTE
  TUTOR
  ESTUDIANTE
}

enum NivelEducativo {
  PRIMARIA
  SECUNDARIA
}

enum EstadoMatricula {
  PENDIENTE
  ACTIVA
  RETIRADA
  FINALIZADA
}

model Usuario {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  rol             Rol
  dosFaActivo     Boolean   @default(false) @map("dos_fa_activo")
  dosFaCodigoHash String?   @map("dos_fa_codigo_hash")
  dosFaExpiraEn   DateTime? @map("dos_fa_expira_en")
  creadoEn        DateTime  @default(now()) @map("creado_en")

  sesiones        SesionRefreshToken[]
  auditLogs       AuditLog[]
  estudiante      Estudiante?
  tutor           Tutor?

  @@map("usuario")
}

model SesionRefreshToken {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  tokenHash String   @map("token_hash")
  expiraEn  DateTime @map("expira_en")
  revocado  Boolean  @default(false)
  creadoEn  DateTime @default(now()) @map("creado_en")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sesion_refresh_token")
}

model AuditLog {
  id              String   @id @default(uuid())
  usuarioId       String   @map("usuario_id")
  accion          String
  entidadAfectada String?  @map("entidad_afectada")
  entidadId       String?  @map("entidad_id")
  fecha           DateTime @default(now())

  usuario         Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("audit_log")
}

model Estudiante {
  id              String    @id @default(uuid())
  usuarioId       String    @unique @map("usuario_id")
  nombres         String
  apellidos       String
  dni             String    @unique
  fechaNacimiento DateTime  @map("fecha_nacimiento")
  creadoEn        DateTime  @default(now()) @map("creado_en")

  usuario         Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tutores         EstudianteTutor[]
  matriculas      Matricula[]

  @@map("estudiante")
}

model Tutor {
  id        String   @id @default(uuid())
  usuarioId String   @unique @map("usuario_id")
  nombres   String
  apellidos String
  dni       String   @unique
  telefono  String?
  creadoEn  DateTime @default(now()) @map("creado_en")

  usuario     Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  estudiantes EstudianteTutor[]

  @@map("tutor")
}

model EstudianteTutor {
  id           String @id @default(uuid())
  estudianteId String @map("estudiante_id")
  tutorId      String @map("tutor_id")
  parentesco   String

  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  tutor        Tutor      @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, tutorId])
  @@map("estudiante_tutor")
}

model Grado {
  id     String         @id @default(uuid())
  nombre String
  nivel  NivelEducativo

  secciones Seccion[]

  @@map("grado")
}

model Seccion {
  id          String @id @default(uuid())
  nombre      String
  gradoId     String @map("grado_id")
  anioEscolar Int    @map("anio_escolar")

  grado      Grado       @relation(fields: [gradoId], references: [id], onDelete: Cascade)
  matriculas Matricula[]

  @@unique([gradoId, nombre, anioEscolar])
  @@map("seccion")
}

model Matricula {
  id             String          @id @default(uuid())
  estudianteId   String          @map("estudiante_id")
  seccionId      String          @map("seccion_id")
  anioEscolar    Int             @map("anio_escolar")
  estado         EstadoMatricula @default(PENDIENTE)
  fechaMatricula DateTime        @default(now()) @map("fecha_matricula")

  estudiante Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Restrict)
  seccion    Seccion    @relation(fields: [seccionId], references: [id], onDelete: Restrict)

  @@map("matricula")
}