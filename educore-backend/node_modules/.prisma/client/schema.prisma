// prisma/schema.prisma
// Coincide con el esquema de la sección 3.1 del informe técnico (tablas usuario y sesion_refresh_token)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  DOCENTE
  TUTOR
  ESTUDIANTE
}

model Usuario {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  rol             Rol
  dosFaActivo     Boolean   @default(false) @map("dos_fa_activo")
  dosFaCodigoHash String?   @map("dos_fa_codigo_hash")
  dosFaExpiraEn   DateTime? @map("dos_fa_expira_en")
  creadoEn        DateTime  @default(now()) @map("creado_en")

  sesiones  SesionRefreshToken[]
  auditLogs AuditLog[]

  @@map("usuario")
}

model SesionRefreshToken {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  tokenHash String   @map("token_hash")
  expiraEn  DateTime @map("expira_en")
  revocado  Boolean  @default(false)
  creadoEn  DateTime @default(now()) @map("creado_en")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sesion_refresh_token")
}

model AuditLog {
  id              String   @id @default(uuid())
  usuarioId       String   @map("usuario_id")
  accion          String
  entidadAfectada String?  @map("entidad_afectada")
  entidadId       String?  @map("entidad_id")
  fecha           DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("audit_log")
}
